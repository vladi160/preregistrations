    "NSC-756645": "Crizotinib (Xalkori, PF-2341066, S1068) — CAS 877399-52-5 — ALK/MET/ROS1 inhibitor",
    "NSC-757441": "Axitinib (Inlyta, AG-013736, S1005) — CAS 319460-85-0 — VEGFR-1/2/3 inhibitor"
  },

  "structural_assignments": {
    "note": "delta_r values from pre-registered experiments ONLY — no new perturbation",
    "NSCLC_network_source": "D3_EGFR_MUTANT_NSCLC_v1 (commit 8dc23d5), examples/egfr_nsclc_signaling.json",
    "MELANOMA_network_source": "D3_BRAF_MELANOMA_v1 (commit 01322af), examples/braf_melanoma_signaling.json",
    "NSCLC_delta_r": {
      "mTOR":  "+0.0047 (DAMPER)",
      "MEK1":  "+0.0040 (DAMPER)",
      "EGFR":  "-0.0009 (near-neutral anchor)",
      "PI3K":  "-0.0151 (ANCHOR)",
      "AKT1":  "-0.0211 (ANCHOR strongest testable)"
    },
    "MELANOMA_delta_r": {
      "MEK1":  "-0.2253 (ANCHOR strongest)",
      "mTOR":  "-0.1096 (ANCHOR)",
      "BRAF":  "-0.0655 (ANCHOR — CLASS 6b driver)",
      "AKT1":  "-0.0652 (ANCHOR)",
      "PI3K":  "-0.0580 (ANCHOR)",
      "EGFR":  "-0.0252 (ANCHOR)"
    },
    "KEY_FINDING": "mTOR is a DAMPER in NSCLC (+0.0047) but an ANCHOR in melanoma (-0.1096). Same drug (everolimus), opposite structural class, different cancer network."
  },

  "almanac_drug_mapping": {
    "718781": {"name": "erlotinib",   "target": "EGFR",            "NSCLC_class": "near-neutral",     "MELANOMA_class": "not_in_network"},
    "715055": {"name": "gefitinib",   "target": "EGFR",            "NSCLC_class": "near-neutral",     "MELANOMA_class": "not_in_network"},
    "745750": {"name": "lapatinib",   "target": "EGFR/HER2",       "NSCLC_class": "near-neutral",     "MELANOMA_class": "not_in_network"},
    "733504": {"name": "everolimus",  "target": "mTOR",            "NSCLC_class": "DAMPER +0.0047",   "MELANOMA_class": "ANCHOR -0.1096"},
    "226080": {"name": "sirolimus",   "target": "mTOR",            "NSCLC_class": "DAMPER +0.0047",   "MELANOMA_class": "ANCHOR -0.1096"},
    "761431": {"name": "vemurafenib", "target": "BRAF V600E",      "NSCLC_class": "not_applicable",   "MELANOMA_class": "ANCHOR -0.0655"},
    "737754": {"name": "pazopanib",   "target": "VEGFR/PDGFR/FGFR","NSCLC_class": "not_in_network",  "MELANOMA_class": "not_in_network"},
    "756645": {"name": "crizotinib",  "target": "ALK/MET/ROS1",    "NSCLC_class": "not_in_network",   "MELANOMA_class": "not_in_network"},
    "757441": {"name": "axitinib",    "target": "VEGFR",           "NSCLC_class": "not_in_network",   "MELANOMA_class": "not_in_network"},
    "747971": {"name": "sorafenib",   "target": "RAF/VEGFR",       "NSCLC_class": "not_in_network",   "MELANOMA_class": "partial_anchor"},
