  MTOR:    -0.767  near-zero
  AKT1:    -0.907  near-zero
  TP53:    -0.580  near-zero
  MDM2:    -0.602  near-zero
  MAP2K1:  -0.476  near-zero
  BRAF:    -0.481  near-zero
